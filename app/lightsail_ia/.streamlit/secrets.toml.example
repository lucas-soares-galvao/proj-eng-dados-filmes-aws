# O arquivo secrets.toml NÃO deve ser commitado (está no .gitignore).
#
# Localização esperada: app/lightsail_ia/.streamlit/secrets.toml
# Na instância Lightsail: o script de deploy copia este arquivo via GitHub Secret.

[auth]
password = "sua-senha-forte-aqui"
